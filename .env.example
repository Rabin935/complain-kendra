MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
PORT=5000
# Optional for Expo native on a physical device.
EXPO_PUBLIC_API_URL=http://192.168.1.100:5000
# Optional for web. Defaults to http://localhost:5000 when the frontend runs on port 3000.
EXPO_PUBLIC_API_URL_WEB=http://localhost:5000
# Google Sign-In frontend config. Use the OAuth Web client because the mobile app sends the
# returned idToken to the backend, which verifies it with google-auth-library before issuing the
# app's own JWT session token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# Optional when you prefer passing the iOS client directly to GoogleSignin.configure().
# If you add GoogleService-Info.plist as described in app.config.ts, this can stay empty.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
